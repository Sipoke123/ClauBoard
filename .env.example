# ─────────────────────────────────────────────────────
# Server (apps/server)
# ─────────────────────────────────────────────────────

# HTTP + WebSocket port
PORT=3001

# Directory for persisted event log (events.jsonl)
DATA_DIR=./data

# Start with mock agents instead of real Claude Code
# Also available via: npm run dev:mock  or  --mock CLI flag
MOCK_AGENTS=false

# Safety: restrict which directories agents can use as cwd.
# Comma-separated absolute paths. If empty, all paths are allowed.
# Example: ALLOWED_WORKSPACE_ROOTS=/home/user/projects,/tmp/sandbox
ALLOWED_WORKSPACE_ROOTS=

# Legacy CLI mode: start a single Claude agent on server boot.
# Usually not needed — prefer launching runs from the UI instead.
# CLAUDE_PROMPT="Your prompt here"
# CLAUDE_CWD=/path/to/working/directory
# CLAUDE_NAME=Claude

# ─────────────────────────────────────────────────────
# Web (apps/web — Next.js)
# ─────────────────────────────────────────────────────

# Override if server runs on a different host/port
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
